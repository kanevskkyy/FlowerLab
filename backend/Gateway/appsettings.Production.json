{
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/api/catalog/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/{**catch-all}" }]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/{**catch-all}" }]
      },
      "order-statuses-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/order-statuses/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/order-statuses/{**catch-all}" }]
      },
      "reviews-route": {
        "ClusterId": "reviews-cluster",
        "Match": { "Path": "/api/reviews/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/{**catch-all}" }]
      },
      "gifts-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/gifts/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/gifts/{**catch-all}" }]
      },
      "auth-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/auth/{**catch-all}" }]
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/{**catch-all}" }]
      },
      "filter-route": {
        "ClusterId": "filter-cluster",
        "Match": { "Path": "/api/aggregator/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/{**catch-all}" }]
      },
      "aggregator-bouquet-route": {
        "ClusterId": "filter-cluster",
        "Match": { "Path": "/api/bouquet/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/bouquet/{**catch-all}" }]
      },
      "aggregator-filters-route": {
        "ClusterId": "filter-cluster",
        "Match": { "Path": "/api/filters/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/filters/{**catch-all}" }]
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog-destination": { "Address": "http://catalog-service:5001" }
        }
      },
      "filter-cluster": {
        "Destinations": {
          "filter-destination": { "Address": "http://aggregator-service:5005" }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders-destination": { "Address": "http://order-service:5002" }
        }
      },
      "reviews-cluster": {
        "Destinations": {
          "reviews-destination": { "Address": "http://review-service:5003" }
        }
      },
      "users-cluster": {
        "Destinations": {
          "users-destination": { "Address": "http://users-service:5004" }
        }
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "https://flowerlab-vlada.com.ua" ]
  }
}
